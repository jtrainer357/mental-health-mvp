{
  "permissions": {
    "allow": ["Bash(npx tsx:*)", "Read(//Users/jaytrainer/**)", "mcp__stitch__list_projects"]
  },
  "mcpServers": {
    "stitch": {
      "command": "/bin/bash",
      "args": ["/Users/jaytrainer/.stitch-mcp/run-proxy.sh"]
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-build-reminder.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-api-audit-warning.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-uncommitted-check.sh"
          }
        ]
      }
    ]
  }
}
